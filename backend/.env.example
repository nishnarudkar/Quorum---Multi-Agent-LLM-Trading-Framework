# ─── Required ─────────────────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# ─── LLM Models (optional — defaults shown) ───────────────────
# Valid Groq models: llama-3.3-70b-versatile, llama-3.1-8b-instant,
#                   mixtral-8x7b-32768, gemma2-9b-it
DEEP_THINK_MODEL=llama-3.3-70b-versatile
QUICK_THINK_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.7
LLM_MAX_RETRIES=3
LLM_TIMEOUT=120
LLM_CONCURRENCY=3

# ─── Pipeline (optional — defaults shown) ─────────────────────
MAX_DEBATE_ROUNDS=2
MAX_RISK_DEBATE_ROUNDS=2
ANALYST_TIMEOUT=60
PIPELINE_TIMEOUT=600
AUTO_TRADE_CONFIDENCE=0.85
ENABLE_HITL=true

# ─── Position Sizing ──────────────────────────────────────────
MAX_POSITION_SIZE=0.25
MIN_POSITION_SIZE=0.01
INITIAL_CAPITAL=100000.0

# ─── Data Cache ───────────────────────────────────────────────
DATA_CACHE_TTL=300

# ─── Alerts (optional) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
DISCORD_WEBHOOK_URL=your_webhook_url

# ─── Paper Trading (optional) ─────────────────────────────────
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── Server (optional) ────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
